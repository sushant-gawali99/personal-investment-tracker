TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

ANTHROPIC_API_KEY=sk-ant-...

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# Set this to your Railway public URL (e.g. https://your-app.up.railway.app)
# If not set, it is auto-detected from RAILWAY_PUBLIC_DOMAIN on Railway
NEXTAUTH_URL=

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email reminders (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=reminders@yourdomain.com

# WhatsApp reminders (Meta Cloud API — set WHATSAPP_ENABLED=true when WABA is ready)
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
